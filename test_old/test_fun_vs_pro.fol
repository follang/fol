// Test comparing function vs procedure parsing

// Function declaration
fun add_pure(a: int, b: int): int = {
    return a + b;
}

// Procedure declaration  
pro add_with_side_effect(a: int, b: int): int = {
    .echo("Adding numbers...");
    return a + b;
}

// Function with options
fun[pure] multiply(x: int, y: int): int = {
    return x * y;
}

// Procedure with options
pro[mut] update_counter(): non = {
    counter = counter + 1;
}