pro[] build(): non = {
    var build = .build();
    build.meta({ name = "core_records", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "core-records",
        root = "src/main.fol",
        fol_model = "core",
    });
    graph.install(app);
    return;
};
