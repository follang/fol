pro[] build(): non = {
    var build = .build();
    build.meta({ name = "alloc_defaults", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "alloc-defaults",
        root = "src/main.fol",
        fol_model = "alloc",
    });
    graph.install(app);
    return;
};
