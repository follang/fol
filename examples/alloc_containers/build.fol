pro[] build(): non = {
    var build = .build();
    build.meta({ name = "alloc_containers", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "alloc-containers",
        root = "src/main.fol",
        fol_model = "mem",
    });
    graph.install(app);
    return;
};
