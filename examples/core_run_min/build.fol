pro[] build(): non = {
    var build = .build();
    build.meta({ name = "core_run_min", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "core-run-min",
        root = "src/main.fol",
        fol_model = "core",
    });
    graph.install(app);
    graph.add_run(app);
    return;
};
