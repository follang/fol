pro[] build(): non = {
    var build = .build();
    build.meta({ name = "shared", version = "0.1.0" });

    var graph = build.graph();
    var lib = graph.add_static_lib({
        name = "shared",
        root = "src/root.fol",
        fol_model = "mem",
    });
    graph.install(lib);
    return;
};
