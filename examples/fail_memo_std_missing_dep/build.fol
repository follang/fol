pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_memo_std_missing_dep", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail_memo_std_missing_dep",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
