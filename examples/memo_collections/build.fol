pro[] build(): non = {
    var build = .build();
    build.meta({ name = "memo_collections", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "memo-collections",
        root = "src/main.fol",
        fol_model = "memo",
    });
    graph.install(app);
    return;
};
