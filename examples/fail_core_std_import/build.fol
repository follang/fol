pro[] build(): non = {
    var build = .build();
    build.meta({ name = "fail_core_std_import", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "fail_core_std_import",
        root = "src/main.fol",
        fol_model = "core",
    });
    graph.install(app);
};
