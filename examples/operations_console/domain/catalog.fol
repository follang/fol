fun[] auth_service(): Service = {
    return SERVICE_AUTH_RECORD
}

fun[] billing_service(): Service = {
    return SERVICE_BILLING_RECORD
}

fun[] edge_service(): Service = {
    return SERVICE_EDGE_RECORD
}

fun[] search_service(): Service = {
    return SERVICE_SEARCH_RECORD
}

fun[] notify_service(): Service = {
    return SERVICE_NOTIFY_RECORD
}

fun[] payments_service(): Service = {
    return SERVICE_PAYMENTS_RECORD
}

fun[] profile_service(): Service = {
    return SERVICE_PROFILE_RECORD
}

fun[] storage_service(): Service = {
    return SERVICE_STORAGE_RECORD
}

fun[] service_keys(): seq[str] = {
    return {
        "auth",
        "billing",
        "edge",
        "search",
        "notify",
        "payments",
        "profile",
        "storage",
    }
}

fun[] region_keys(): seq[str] = {
    return {
        "eu",
        "us",
        "apac",
    }
}

fun[] service_weights(): map[str, int] = {
    return {
        {"auth", 5},
        {"billing", 7},
        {"edge", 3},
        {"search", 4},
        {"notify", 2},
        {"payments", 7},
        {"profile", 4},
        {"storage", 6},
    }
}

fun[] severity_codes(): map[str, int] = {
    return {
        {"low", 1},
        {"medium", 3},
        {"high", 5},
        {"critical", 7},
    }
}

fun[] load_remote_owner(flag: bol): str / str = {
    when(flag) {
        case(true) { report "owner-directory-offline" }
        * { return "platform-ops" }
    }
}

fun[] load_backup_owner(flag: bol): str / str = {
    when(flag) {
        case(true) { report "backup-roster-stale" }
        * { return "fallback-ops" }
    }
}

fun[] owner_with_fallback(flag: bol): str = {
    return load_remote_owner(flag) || "fallback-ops"
}

fun[] owner_check(flag: bol): bol = {
    return check(load_remote_owner(flag))
}

fun[] owner_directory_status(flag: bol): int = {
    when(check(load_remote_owner(flag))) {
        case(true) { return 70 }
        * { return 30 }
    }
}

fun[] optional_runbook(flag: bol): MaybeText = {
    when(flag) {
        case(true) { return "rotate-secrets" }
        * { return nil }
    }
}

fun[] runbook_auth(flag: bol): str = {
    when(flag) {
        case(true) { return optional_runbook(true)! }
        * { return "rotate-secrets" }
    }
}

fun[] runbook_billing(flag: bol): str = {
    when(flag) {
        case(true) { return optional_runbook(true)! }
        * { return "confirm-ledger" }
    }
}

fun[] runbook_edge(flag: bol): str = {
    when(flag) {
        case(true) { return optional_runbook(true)! }
        * { return "roll-cache" }
    }
}

fun[] runbook_payments(flag: bol): str = {
    when(flag) {
        case(true) { return optional_runbook(true)! }
        * { return "gate-retries" }
    }
}

fun[] severity_code(severity: Severity): int = {
    when(severity) {
        case(Severity.LOW) { return 1 }
        case(Severity.MEDIUM) { return 3 }
        case(Severity.HIGH) { return 5 }
        * { return 7 }
    }
}

fun[] healthy(flag: bol): Health = {
    when(flag) {
        case(true) { return Health.BLOCKED }
        * { return Health.READY }
    }
}

fun[] ready(flag: bol): bol = {
    return .not(flag)
}

fun[] snapshot(service: Service, flag: bol): ServiceSnapshot = {
    var level: Severity = service.severity
    return {
        name = service.name,
        owner = owner_with_fallback(flag),
        severity = level,
        severity_code = severity_code(level),
        health = healthy(flag),
        ready = ready(flag),
    }
}

fun[] snapshot_auth(flag: bol): ServiceSnapshot = {
    return snapshot(auth_service(), flag)
}

fun[] snapshot_billing(flag: bol): ServiceSnapshot = {
    return snapshot(billing_service(), flag)
}

fun[] snapshot_edge(flag: bol): ServiceSnapshot = {
    return snapshot(edge_service(), flag)
}

fun[] snapshot_search(flag: bol): ServiceSnapshot = {
    return snapshot(search_service(), flag)
}

fun[] snapshot_notify(flag: bol): ServiceSnapshot = {
    return snapshot(notify_service(), flag)
}

fun[] snapshot_payments(flag: bol): ServiceSnapshot = {
    return snapshot(payments_service(), flag)
}

fun[] snapshot_profile(flag: bol): ServiceSnapshot = {
    return snapshot(profile_service(), flag)
}

fun[] snapshot_storage(flag: bol): ServiceSnapshot = {
    return snapshot(storage_service(), flag)
}

fun[] auth_audit(flag: bol): AuditRow = {
    var item: ServiceSnapshot = snapshot_auth(flag)
    return {
        label = item.name,
        owner = item.owner,
        severity_code = item.severity_code,
        stable = item.ready,
    }
}

fun[] billing_audit(flag: bol): AuditRow = {
    var item: ServiceSnapshot = snapshot_billing(flag)
    return {
        label = item.name,
        owner = item.owner,
        severity_code = item.severity_code,
        stable = item.ready,
    }
}

