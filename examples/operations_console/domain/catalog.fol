ali ServiceName: str
ali OwnerName: str
ali RegionName: str
ali MaybeText: opt[str]

typ Severity: ent = {
    var LOW: int = 1;
    var MEDIUM: int = 3;
    var HIGH: int = 5;
    var CRITICAL: int = 7
}

typ Health: ent = {
    var READY: int = 11;
    var DEGRADED: int = 13;
    var BLOCKED: int = 17
}

typ Region: ent = {
    var EU: int = 21;
    var US: int = 22;
    var APAC: int = 23
}

typ Tier: ent = {
    var EDGE: int = 31;
    var CONTROL: int = 32;
    var DATA: int = 33
}

typ Contact: rec = {
    team: str;
    room: str;
    shift: str
}

typ Service: rec = {
    name: ServiceName;
    region: Region;
    severity: Severity;
    tier: Tier;
    owner: OwnerName;
    runbook: str
}

typ ServiceSnapshot: rec = {
    name: str;
    owner: str;
    severity: Severity;
    severity_code: int;
    health: Health;
    ready: bol
}

typ AuditRow: rec = {
    label: str;
    owner: str;
    severity_code: int;
    stable: bol
}

fun (Service)display_code(): int = {
    return 7
}

var CORE_CONTACT: Contact = {
    team = "core-platform",
    room = "ams-1",
    shift = "day",
}

var EDGE_CONTACT: Contact = {
    team = "edge-platform",
    room = "ams-2",
    shift = "swing",
}

var DATA_CONTACT: Contact = {
    team = "data-platform",
    room = "ams-3",
    shift = "night",
}

