fun[] audit_labels(): seq[str] = {
    return {
        "auth",
        "billing",
        "edge",
        "search",
        "notify",
        "payments",
        "profile",
        "storage",
    }
}

fun[] audit_total(): int = {
    return .len(audit_labels())
}

fun[] service_total(): int = {
    return .len(service_keys())
}

fun[] catalog_ready(flag: bol): bol = {
    return .eq(owner_directory_status(flag), 70)
}

fun[] critical_service_name(): str = {
    return payments_service().name
}

fun[] auth_name(): str = {
    return auth_service().name
}

fun[] billing_name(): str = {
    return billing_service().name
}

fun[] edge_name(): str = {
    return edge_service().name
}

fun[] stable_contact_name(): str = {
    return CORE_CONTACT.team
}

fun[] region_contact(region: Region): Contact = {
    when(region) {
        case(Region.EU) { return CORE_CONTACT }
        case(Region.US) { return DATA_CONTACT }
        * { return EDGE_CONTACT }
    }
}

fun[] region_label(region: Region): str = {
    when(region) {
        case(Region.EU) { return "eu" }
        case(Region.US) { return "us" }
        * { return "apac" }
    }
}

fun[] severity_label(severity: Severity): str = {
    when(severity) {
        case(Severity.LOW) { return "low" }
        case(Severity.MEDIUM) { return "medium" }
        case(Severity.HIGH) { return "high" }
        * { return "critical" }
    }
}

fun[] health_label(health: Health): str = {
    when(health) {
        case(Health.READY) { return "ready" }
        case(Health.DEGRADED) { return "degraded" }
        * { return "blocked" }
    }
}
