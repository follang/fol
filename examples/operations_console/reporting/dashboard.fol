ali BoardName: str
ali MaybeMessage: opt[str]

typ Attention: ent = {
    var GREEN: int = 41;
    var YELLOW: int = 42;
    var RED: int = 43
}

typ DashboardLine: rec = {
    label: str;
    owner: str;
    code: int;
    stable: bol
}

typ Dashboard: rec = {
    name: BoardName;
    headline: str;
    owner: str;
    primary_code: int;
    release_title: str
}

typ ReleaseBoard: rec = {
    name: str;
    owner: str;
    release_note: str;
    ready: bol;
    exit_code: int
}

typ PackageState: rec = {
    label: str;
    attention: Attention;
    code: int
}

fun[] attention_from_code(code: int): Attention = {
    when(.gt(code, 5)) {
        case(true) { return Attention.RED }
        * {
            when(.gt(code, 3)) {
                case(true) { return Attention.YELLOW }
                * { return Attention.GREEN }
            }
        }
    }
}

fun[] code_from_attention(value: Attention): int = {
    when(value) {
        case(Attention.GREEN) { return 1 }
        case(Attention.YELLOW) { return 5 }
        * { return 7 }
    }
}

fun[] line_from_snapshot(item: domain::ServiceSnapshot): DashboardLine = {
    return {
        label = item.name,
        owner = item.owner,
        code = item.severity_code,
        stable = item.ready,
    }
}

fun[] auth_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_auth(flag))
}

fun[] billing_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_billing(flag))
}

fun[] edge_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_edge(flag))
}

fun[] search_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_search(flag))
}

fun[] notify_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_notify(flag))
}

fun[] payments_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_payments(flag))
}

fun[] profile_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_profile(flag))
}

fun[] storage_line(flag: bol): DashboardLine = {
    return line_from_snapshot(domain::snapshot_storage(flag))
}

fun[] line_code(item: DashboardLine): int = {
    return item.code
}

fun[] line_stable(item: DashboardLine): bol = {
    return item.stable
}

fun[] line_label(item: DashboardLine): str = {
    return item.label
}

fun[] attention_from_snapshot(item: domain::ServiceSnapshot): Attention = {
    return attention_from_code(item.severity_code)
}

fun[] package_auth(flag: bol): PackageState = {
    var item: domain::ServiceSnapshot = domain::snapshot_auth(flag)
    return {
        label = item.name,
        attention = attention_from_snapshot(item),
        code = item.severity_code,
    }
}

