pro[] build(): non = {
    var build = .build();
    build.meta({ name = "std_cli", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "std-cli",
        root = "src/main.fol",
        fol_model = "std",
    });
    graph.install(app);
    graph.add_run(app);
    return;
};
