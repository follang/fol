pro[] build(): non = {
    var build = .build();
    build.meta({ name = "shared", version = "0.1.0" });

    var graph = build.graph();
    var assets = graph.add_system_tool_dir({
        tool = "assetpack",
        output_dir = "gen/assets",
    });

    build.export_dir({ name = "assets", dir = assets });
    return;
};
