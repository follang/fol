pro[] build(): non = {
    var graph = .graph();
    var corelib = graph.add_static_lib({
        name = "corelib",
        root = "core/lib.fol",
        fol_model = "core",
    });
    var alloclib = graph.add_static_lib({
        name = "alloclib",
        root = "alloc/lib.fol",
        fol_model = "alloc",
    });
    var tool = graph.add_exe({
        name = "tool",
        root = "app/main.fol",
        fol_model = "std",
    });

    graph.install(tool);
    graph.add_run(tool);
};
