pro[] build(): non = {
    var build = .build();
    build.meta({ name = "shared", version = "0.1.0" });
    var graph = build.graph();
    var target = graph.standard_target();
    var optimize = graph.standard_optimize();
    var lib = graph.add_static_lib({
        name = "shared",
        root = "src/lib.fol",
        target = target,
        optimize = optimize,
    });

    graph.install(lib);
};
