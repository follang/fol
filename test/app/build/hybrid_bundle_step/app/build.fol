pro[] build(): non = {
    var build = .build();
    build.meta({ name = "app", version = "0.1.0" });
    var graph = build.graph();
    var target = graph.standard_target();
    var optimize = graph.standard_optimize();
    var app = graph.add_exe({
        name = "bundle_app",
        root = "src/main.fol",
        target = target,
        optimize = optimize,
    });
    var run_app = graph.add_run(app);
    var install_app = graph.install(app);

    graph.step("bundle", run_app, install_app);
};
