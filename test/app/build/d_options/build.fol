pro[] build(graph: Graph): non = {
    var target   = graph.standard_target();
    var optimize = graph.standard_optimize();
    var root_opt = graph.option({ name = "root", kind = "path", default = "src/main.fol" });
    var app = graph.add_exe({
        name     = "app",
        root     = root_opt,
        target   = target,
        optimize = optimize,
    });
    graph.install(app);
    graph.add_run(app);
}
