fun[] make_static_lib(name: str, root: str): Artifact = {
    return .graph().add_static_lib({ name = name, root = root });
};

pro[] build(): non = {
    var graph = .graph();
    var core = make_static_lib("core", "src/core/lib.fol");
    var io   = make_static_lib("io",   "src/io/lib.fol");
    var app  = graph.add_exe({ name = "app", root = "src/main.fol" });
    app.link(core);
    app.link(io);
    graph.install(app);
    graph.add_run(app);
};
