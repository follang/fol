pro[] build(): non = {
    var build = .build();
    build.meta({ name = "model_std_hosted_alloc", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "model_std_hosted_alloc",
        root = "src/main.fol",
        fol_model = "std",
    });

    graph.install(app);
    graph.add_run(app);
};
