pro[] build(): non = {
    var build = .build();
    build.meta({ name = "model_alloc_reject_echo", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "model_alloc_reject_echo",
        root = "src/main.fol",
        fol_model = "alloc",
    });

    graph.install(app);
};
