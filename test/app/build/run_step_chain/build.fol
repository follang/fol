pro[] build(graph: Graph): non = {
    var target = graph.standard_target();
    var optimize = graph.standard_optimize();
    var lint = graph.step("lint");
    var app = graph.add_exe({
        name = "run_step_chain",
        root = "src/main.fol",
        target = target,
        optimize = optimize,
    });

    var run = graph.add_run(app);
    run.depend_on(lint);
    var inst = graph.install(app);
    inst.depend_on(lint);
};
