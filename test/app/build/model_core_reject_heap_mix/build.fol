pro[] build(): non = {
    var build = .build();
    build.meta({ name = "model_core_reject_heap_mix", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "model_core_reject_heap_mix",
        root = "src/main.fol",
        fol_model = "core",
    });

    graph.install(app);
};
