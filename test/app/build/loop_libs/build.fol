pro[] build(): non = {
    var build = .build();
    build.meta({ name = "loop_libs", version = "0.1.0" });
    var graph = build.graph();
    loop(name in {"core", "io", "utils"}) {
        graph.add_static_lib({ name = name, root = name });
    };
    var app = graph.add_exe({ name = "app", root = "src/main.fol" });
    graph.install(app);
};
