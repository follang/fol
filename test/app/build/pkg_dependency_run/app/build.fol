pro[] build(): non = {
    var build = .build();
    build.meta({ name = "app", version = "0.1.0" });
    var graph = build.graph();
    var target = graph.standard_target();
    var optimize = graph.standard_optimize();
    var app = graph.add_exe({
        name = "pkg_dependency_run_app",
        root = "src/main.fol",
        target = target,
        optimize = optimize,
    });

    graph.install(app);
    graph.add_run(app);
};
