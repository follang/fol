pro[] build(): non = {
    var build = .build();
    build.meta({ name = "model_std_echo", version = "0.1.0" });
    build.add_dep({ alias = "std", source = "internal", target = "standard" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "model_std_echo",
        root = "src/main.fol",
        fol_model = "memo",
    });

    graph.install(app);
    graph.add_run(app);
};
