pro[] build(): non = {
    var graph = .graph();
    var app = graph.add_exe({
        name = "generated_file",
        root = "src/main.fol",
    });
    var version = graph.write_file({
        name = "version",
        path = "gen/version.fol",
        contents = "generated",
    });

    graph.install(app);
    graph.add_run(app);
};
