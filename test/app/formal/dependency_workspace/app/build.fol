pro[] build(): non = {
    var build = .build();
    build.meta({ name = "dependency_workspace_app", version = "0.1.0" });
    var graph = build.graph();
    var app = graph.add_exe({
        name = "dependency_workspace_app",
        root = "src/main.fol",
    });

    graph.install(app);
    graph.add_run(app);
};
