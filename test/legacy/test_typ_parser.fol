// Test file for type declaration parsing

// Basic record type
typ Point: rec = {
    var x: int;
    var y: int;
}

// Record type with options
typ[pub] Color: rec = {
    var r: int[u8];
    var g: int[u8];
    var b: int[u8];
}

// Type with generics
typ[T: gen[]] Box: rec = {
    var value: T;
}

// Entity type
typ Person: ent = {
    var name: str;
    var age: int;
}

// Type with methods
typ Counter: rec = {
    var count: int;
    
    fun increment(): int = {
        count = count + 1;
        count
    }
}

// Grouped type declarations
typ (
    First: rec = { var a: int; }
    Second: rec = { var b: flt; }
    Third: rec = { var c: chr; }
)