ali MaybeScore: opt[int];

fun[] maybe(flag: bol): MaybeScore = {
    when(flag) {
        case(true) { return 7; }
        * { return nil; }
    }
};

fun[] load(flag: bol): int / str = {
    when(flag) {
        case(true) { report "bad-input"; }
        * { return 7; }
    }
};

fun[] main(flag: bol): int = {
    var shell_value: int = maybe(true)!;
    return load(flag) || shell_value;
};
