fun[] load(flag: bol): int / str = {
    when(flag) {
        case(true) { report "bad-input"; }
        * { return 7; }
    }
}

fun[] forward(flag: bol): int / str = {
    return load(flag) || report "forward-bad-input";
}

fun[] main(): int / str = {
    return forward(true) || report "main-bad-input";
}
