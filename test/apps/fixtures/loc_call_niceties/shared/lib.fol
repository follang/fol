typ[exp] Counter: rec = {
    total: int
};

fun[exp] pair(left: int, right: int = 2): int = {
    return left + right;
};

fun[exp] score(base: int, step: int = 2, extras: ... int): int = {
    return base + step + extras[0] + extras[1] + .len(extras);
};

fun[exp] (Counter)shift(step: int = 2, extras: ... int): int = {
    return step + extras[0] + extras[1] + .len(extras);
};

fun[exp] lead(): Counter = {
    return {
        total = 9,
    };
};
