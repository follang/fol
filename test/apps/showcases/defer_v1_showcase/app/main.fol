fun[] show(value: int): int = {
    return .echo(value);
};

fun[] loop_demo(): int = {
    defer {
        show(10);
    };
    loop(true) {
        defer {
            show(20);
        };
        show(30);
        break;
    }
    return show(40);
};

fun[] main(): int = {
    defer {
        show(50);
    };
    {
        defer {
            show(60);
        };
        loop_demo();
    }
    return show(70);
};
