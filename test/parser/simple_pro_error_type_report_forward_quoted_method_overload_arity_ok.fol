typ Parser: rec = { };

pro caller_forward_quoted_method_overload_ok(tool: Parser, a: int, b: int): int / str = {
    report tool."$make_err"(a, b);
    return 0;
};

fun (Parser)"$make_err"(code: int): int = {
    return code;
};

fun (Parser)"$make_err"(code: int, mode: int): str = {
    return "err";
};
